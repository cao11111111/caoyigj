{
  "miniprogramRoot": "./dist",
  "projectname": "曹一工具箱",
  "description": "曹一工具箱 - 知识卡片生成工具",
  "appid": "",
  "setting": {
    "urlCheck": false,
    "es6": true,
    "enhance": true,
    "compileHotReLoad": true,
    "postcss": true,
    "minified": false,
    "bigPackageSizeSupport": true
  },
  "compileType": "miniprogram",
  "libVersion": "3.4.6",
  "packOptions": {
    "ignore": [
      { "type": "folder", "value": "./assets" },
      { "type": "folder", "value": "./node_modules" }
    ]
  }
}
